# Copiar este archivo a .env.local y completar con los valores reales
# del proyecto de Supabase (Project Settings > API).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (Project Settings > API > service_role) — NUNCA exponer
# al cliente, NUNCA prefijar con NEXT_PUBLIC_. Solo se usa en
# src/lib/supabase/admin.ts para leer/escribir datos sensibles (tokens de
# Mercado Pago) que las policies de RLS bloquean incluso para su dueño.
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago (Fase 4) — credenciales de la aplicación (dashboard de
# Mercado Pago Developers > Tus integraciones > tu app).
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_CLIENT_ID=
MP_CLIENT_SECRET=
MP_OAUTH_REDIRECT_URI=
# Firma secreta del webhook (Tus integraciones > tu app > Webhooks)
MP_WEBHOOK_SECRET=

# Bandeja de Instagram — ver docs/inbox-setup.md para los pasos de Meta.
# App secret de la app de Meta (App settings > Basic > App secret) — firma
# el webhook (X-Hub-Signature-256) sobre el body crudo.
META_APP_SECRET=
# String propio (lo inventás vos) que Meta te devuelve tal cual en el
# handshake de verificación del webhook (hub.verify_token).
META_WEBHOOK_VERIFY_TOKEN=
# IGSID de la cuenta de Instagram profesional conectada a la app.
IG_USER_ID=
# El access token de Instagram de larga duración NO va acá: se guarda en
# la tabla social_settings (rota cada 60 días vía el cron de refresh) para
# no tener que redeployar cada vez que se renueva.

# Clasificación de mensajes con Claude (console.anthropic.com > API Keys).
ANTHROPIC_API_KEY=

# Protege /api/cron/refresh-ig-token — Vercel manda este valor en el
# header Authorization de las invocaciones de vercel.json; generá un
# string random propio.
CRON_SECRET=

# true = la bandeja loguea el envío en vez de llamar a la Graph API de
# verdad. Útil para desarrollar el flujo de aprobación sin un token real
# de Instagram todavía. Aplica también a los envíos de WhatsApp.
INBOX_DRY_RUN=

# Bandeja de WhatsApp (Cloud API + Coexistence) — ver sección
# correspondiente en README.md para los pasos de Meta.
# Token permanente del system user (Business Settings > System users).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# String propio (lo inventás vos), igual que META_WEBHOOK_VERIFY_TOKEN
# pero para la suscripción del webhook de WhatsApp.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# App secret de la app de Meta usada para WhatsApp (puede ser una app
# distinta de la de Instagram) — firma X-Hub-Signature-256.
WHATSAPP_APP_SECRET=
