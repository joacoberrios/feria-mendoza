# Copiar este archivo a .env.local y completar con los valores reales
# del proyecto de Supabase (Project Settings > API).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (Project Settings > API > service_role) — NUNCA exponer
# al cliente, NUNCA prefijar con NEXT_PUBLIC_. Solo se usa en
# src/lib/supabase/admin.ts para leer/escribir datos sensibles (tokens de
# Mercado Pago) que las policies de RLS bloquean incluso para su dueño.
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago (Fase 4) — credenciales de la aplicación (dashboard de
# Mercado Pago Developers > Tus integraciones > tu app).
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_CLIENT_ID=
MP_CLIENT_SECRET=
MP_OAUTH_REDIRECT_URI=
# Firma secreta del webhook (Tus integraciones > tu app > Webhooks)
MP_WEBHOOK_SECRET=
